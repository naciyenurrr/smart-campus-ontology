@prefix : <http://www.example.org/smartcampus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.example.org/smartcampus> a owl:Ontology .

############################
### CLASS HIERARCHY
############################

:Person a owl:Class .

:Student a owl:Class ;
    rdfs:subClassOf :Person .

:Professor a owl:Class ;
    rdfs:subClassOf :Person .

:Course a owl:Class .

:Department a owl:Class .

:Building a owl:Class .

:Facility a owl:Class ;
    rdfs:subClassOf :Building .

:Laboratory a owl:Class ;
    rdfs:subClassOf :Facility .

:Classroom a owl:Class ;
    rdfs:subClassOf :Facility .

############################
### OBJECT PROPERTIES
############################

:takesCourse a owl:ObjectProperty ;
    rdfs:domain :Student ;
    rdfs:range :Course ;
    owl:inverseOf :isTakenBy .

:isTakenBy a owl:ObjectProperty ;
    rdfs:domain :Course ;
    rdfs:range :Student .

:teachesCourse a owl:ObjectProperty ;
    rdfs:domain :Professor ;
    rdfs:range :Course ;
    owl:inverseOf :isTaughtBy .

:isTaughtBy a owl:ObjectProperty ;
    rdfs:domain :Course ;
    rdfs:range :Professor .

:belongsToDepartment a owl:ObjectProperty ;
    rdfs:domain :Person ;
    rdfs:range :Department .

:hasMember a owl:ObjectProperty ;
    rdfs:domain :Department ;
    rdfs:range :Person ;
    owl:inverseOf :belongsToDepartment .

:locatedIn a owl:ObjectProperty ;
    rdfs:domain :Facility ;
    rdfs:range :Building .

:hasFacility a owl:ObjectProperty ;
    rdfs:domain :Building ;
    rdfs:range :Facility ;
    owl:inverseOf :locatedIn .

############################
### DATA PROPERTIES
############################

:studentID a owl:DatatypeProperty ;
    rdfs:domain :Student ;
    rdfs:range xsd:string .

:name a owl:DatatypeProperty ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:courseCode a owl:DatatypeProperty ;
    rdfs:domain :Course ;
    rdfs:range xsd:string .

:credits a owl:DatatypeProperty ;
    rdfs:domain :Course ;
    rdfs:range xsd:int .

:capacity a owl:DatatypeProperty ;
    rdfs:domain :Classroom ;
    rdfs:range xsd:int .

############################
### RESTRICTIONS (ADVANCED)
############################

:Student rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :takesCourse ;
    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :Course
] .

:Course rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :isTaughtBy ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :Professor
] .

############################
### INSTANCES
############################

:AI_Department a :Department .

:Berat a :Student ;
    :name "Berat Yılmaz" ;
    :studentID "S001" ;
    :takesCourse :DeepLearning_101 ;
    :belongsToDepartment :AI_Department .

:Naciye a :Student ;
    :name "Naciye Nur Akkuş" ;
    :studentID "S002" ;
    :takesCourse :DeepLearning_101 ;
    :belongsToDepartment :AI_Department .

:DeepLearning_101 a :Course ;
    :courseCode "DL101" ;
    :credits 6 ;
    :isTaughtBy :Prof_Ahmet .

:Prof_Ahmet a :Professor ;
    :name "Ahmet Demir" ;
    :belongsToDepartment :AI_Department .

:EngineeringBuilding a :Building .

:OntologyLab a :Laboratory ;
    :locatedIn :EngineeringBuilding .

:Room101 a :Classroom ;
    :capacity 40 ;
    :locatedIn :EngineeringBuilding .
