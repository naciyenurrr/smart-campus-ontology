@prefix : <http://www.example.org/jobontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.example.org/jobontology> a owl:Ontology .

############################
### CLASSES
############################

:Person a owl:Class .

:Candidate a owl:Class ;
    rdfs:subClassOf :Person .

:Recruiter a owl:Class ;
    rdfs:subClassOf :Person .

:Job a owl:Class .

:Company a owl:Class .

:Skill a owl:Class .

:TechnicalSkill a owl:Class ;
    rdfs:subClassOf :Skill .

:SoftSkill a owl:Class ;
    rdfs:subClassOf :Skill .

:ExperienceLevel a owl:Class .

:Education a owl:Class .

:Certification a owl:Class .

:Location a owl:Class .

############################
### OBJECT PROPERTIES
############################

:hasSkill a owl:ObjectProperty ;
    rdfs:domain :Candidate ;
    rdfs:range :Skill .

:requiresSkill a owl:ObjectProperty ;
    rdfs:domain :Job ;
    rdfs:range :Skill .

:hasCertification a owl:ObjectProperty ;
    rdfs:domain :Candidate ;
    rdfs:range :Certification .

:requiresCertification a owl:ObjectProperty ;
    rdfs:domain :Job ;
    rdfs:range :Certification .

:hasEducation a owl:ObjectProperty ;
    rdfs:domain :Candidate ;
    rdfs:range :Education .

:offeredBy a owl:ObjectProperty ;
    rdfs:domain :Job ;
    rdfs:range :Company .

:locatedIn a owl:ObjectProperty ;
    rdfs:domain :Job ;
    rdfs:range :Location .

:preferredLocation a owl:ObjectProperty ;
    rdfs:domain :Candidate ;
    rdfs:range :Location .

############################
### DATA PROPERTIES
############################

:name a owl:DatatypeProperty ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:jobTitle a owl:DatatypeProperty ;
    rdfs:domain :Job ;
    rdfs:range xsd:string .

:salary a owl:DatatypeProperty ;
    rdfs:domain :Job ;
    rdfs:range xsd:int .

:yearsOfExperience a owl:DatatypeProperty ;
    rdfs:domain :Candidate ;
    rdfs:range xsd:int .

:skillLevel a owl:DatatypeProperty ;
    rdfs:domain :Candidate ;
    rdfs:range xsd:string .

:jobType a owl:DatatypeProperty ;
    rdfs:domain :Job ;
    rdfs:range xsd:string .  # Full-time, Remote, Hybrid

############################
### SKILL HIERARCHY
############################

:Programming a :TechnicalSkill .
:Python a :TechnicalSkill ;
    rdfs:subClassOf :Programming .

:MachineLearning a :TechnicalSkill .

:Communication a :SoftSkill .

############################
### INSTANCES
############################

### Locations
:Istanbul a :Location .
:Remote a :Location .

### Company
:TechCorp a :Company .

### Job
:AI_Engineer_Job a :Job ;
    :jobTitle "AI Engineer" ;
    :requiresSkill :Python , :MachineLearning ;
    :requiresCertification :ML_Certificate ;
    :salary 50000 ;
    :jobType "Remote" ;
    :locatedIn :Remote ;
    :offeredBy :TechCorp .

### Certification
:ML_Certificate a :Certification .

### Candidate
:Naciye a :Candidate ;
    :name "Naciye Nur Akkuş" ;
    :hasSkill :Python ;
    :skillLevel "Intermediate" ;
    :yearsOfExperience 2 ;
    :preferredLocation :Remote .

:Berat a :Candidate ;
    :name "Berat Yılmaz" ;
    :hasSkill :Python , :MachineLearning ;
    :hasCertification :ML_Certificate ;
    :yearsOfExperience 4 ;
    :preferredLocation :Istanbul .
